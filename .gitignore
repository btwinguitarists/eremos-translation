# Cloned source texts (pulled from upstream repos, not our code)
# Keep bsb-text/ — small CC0 plain-text reference we want checked in
sources/SBLGNT/
sources/macula-greek/
sources/bsb/
sources/TNBT/
sources/en_tn/
sources/en_tw/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Env / secrets
.env
.env.local

# OS
.DS_Store

# Redundant combined-book extract files (per-chapter files cover same content)
output/**/*_verses.json

# Extracted Greek source-data caches — reproducible via scripts/extract_book.py.
# Only actual translation artifacts are tracked. The whitelist below keeps the
# folders that represent real translation work; everything else under output/
# is treated as a cache.
output/*/
!output/translations/
!output/back_translations/
!output/uw_notes/
!output/check_reports/
!output/reader/
!output/plain/
!output/feedback/
!output/textual_variants/
!output/translator_notes/
!output/paratext/

# Demo/scratch files
output/translations/*_demo.json

# Auto-regen BT prompt placeholders (regenerate when checks run; not source of truth)
output/back_translations/*_PROMPT.md

# Loop output
logs/

# Runtime markers written by detect_book_complete.py (consumed by ship loop +
# scripts/run_end_of_book_audit.sh; regenerated each ship; not source-of-truth)
output/.book_complete_signal
output/.book_complete_audit_prompt.md

# Audit-items-to-YAML output dirs (temp; copied to EremosVercel2/shared/review-questions/
# by the audit agent — not source-of-truth on this side)
output/review_questions_*/
